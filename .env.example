# Looma reads secrets from the OS keychain at runtime (see fly-secrets).
# This file documents the keys you can configure in Settings — values entered
# in the app are stored in the keychain, NOT in a .env file.
#
# These environment variables are only honored in development as a convenience
# and are never required.

# LLM providers (bring your own key; pick one or more in Settings)
LOOMA_OPENAI_API_KEY=
LOOMA_ANTHROPIC_API_KEY=
LOOMA_NVIDIA_NIM_API_KEY=
# Ollama needs no key — just a local ollama serve (default http://localhost:11434)
LOOMA_OLLAMA_BASE_URL=

# Cloud transcription fallback (optional; audio leaves the device when used)
LOOMA_GROQ_API_KEY=

# Calendar OAuth (bring your own app registrations)
LOOMA_GOOGLE_CLIENT_ID=
LOOMA_GOOGLE_CLIENT_SECRET=
LOOMA_MS_CLIENT_ID=
